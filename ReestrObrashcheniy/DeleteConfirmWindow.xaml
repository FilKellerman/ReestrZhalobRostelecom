<Window x:Class="ReestrObrashcheniy.DeleteConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подтверждение удаления" 
        Height="240" Width="480"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Фирменные цвета Ростелекома -->
        <SolidColorBrush x:Key="RostelecomBlue" Color="#0055A5"/>
        <SolidColorBrush x:Key="RostelecomRed" Color="#E74C3C"/>
        <SolidColorBrush x:Key="RostelecomRedHover" Color="#FF4D4D"/>
        <SolidColorBrush x:Key="RostelecomGray" Color="#6C757D"/>
        <SolidColorBrush x:Key="GrayDark" Color="#333333"/>
        <SolidColorBrush x:Key="GrayLight" Color="#D0D7E0"/>

        <!-- Стиль кнопки -->
        <Style x:Key="RtlButton" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Красная кнопка "Да, удалить" -->
        <Style x:Key="RtlDangerButton" BasedOn="{StaticResource RtlButton}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource RostelecomRed}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RostelecomRedHover}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CC0000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Вторичная кнопка "Отмена" -->
        <Style x:Key="RtlSecondaryButton" BasedOn="{StaticResource RtlButton}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource RostelecomGray}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5A6268"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль TextBlock -->
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource GrayDark}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Заголовок -->
        <Border Background="{StaticResource RostelecomBlue}" Height="50" VerticalAlignment="Top">
            <TextBlock Text="Подтверждение удаления"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Основное содержимое -->
        <Grid Margin="20,60,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Вы действительно хотите удалить?" 
                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource RostelecomRed}"/>

            <TextBlock x:Name="txtКлиентИнфо" Grid.Row="1" FontSize="14" Margin="0,-10,0,20"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Отмена" Style="{StaticResource RtlSecondaryButton}" Click="BtnNo_Click"/>
                <Button Content="Да, удалить" Style="{StaticResource RtlDangerButton}" Margin="15,0,0,0" Click="BtnYes_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>