<Window x:Class="ReestrObrashcheniy.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" 
        Height="590" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Фирменные цвета Ростелеком -->
        <SolidColorBrush x:Key="RostelecomBlue" Color="#0055A5"/>
        <SolidColorBrush x:Key="RostelecomBlueHover" Color="#0077CC"/>

        <Style TargetType="Button" x:Key="RtlPrimaryButton">
            <Setter Property="Background" Value="{StaticResource RostelecomBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RostelecomBlueHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="{StaticResource RostelecomBlue}" Height="50" CornerRadius="6" Grid.Row="0">
            <TextBlock Text="Настройки программы" 
                       Foreground="White" 
                       FontSize="18" 
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Основное содержимое -->
        <StackPanel Grid.Row="1" Margin="0,20,0,20">

            <!-- Тема оформления -->
            <GroupBox Header="Внешний вид" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Тема оформления:" Margin="0,0,0,8" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cmbTheme" Height="32">
                        <ComboBoxItem Content="Светлая"/>
                        <ComboBoxItem Content="Тёмная" IsSelected="True"/>
                    </ComboBox>

                    <TextBlock Text="Масштаб интерфейса:" Margin="0,15,0,8" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cmbScale" Height="32">
                        <ComboBoxItem Content="75%"/>
                        <ComboBoxItem Content="100%" IsSelected="True"/>
                        <ComboBoxItem Content="125%"/>
                        <ComboBoxItem Content="150%"/>
                    </ComboBox>

                    <TextBlock Text="Шрифт:" Margin="0,15,0,8" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cmbFont" Height="32">
                        <ComboBoxItem Content="Arial" IsSelected="True"/>
                        <ComboBoxItem Content="Calibri"/>
                        <ComboBoxItem Content="Segoe UI"/>
                        <ComboBoxItem Content="Verdana"/>
                    </ComboBox>
                </StackPanel>
            </GroupBox>

            <!-- Автобэкап -->
            <GroupBox Header="Резервное копирование" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <CheckBox x:Name="chkAutoBackup" 
                              Content="Включить автоматическое резервное копирование" 
                              IsChecked="True" Margin="0,0,0,12"/>

                    <DockPanel>
                        <TextBlock Text="Интервал (дней):" 
                                   VerticalAlignment="Center" 
                                   DockPanel.Dock="Left"/>
                        <TextBox x:Name="txtBackupInterval" 
                                 Width="80" Height="28" 
                                 HorizontalAlignment="Right" 
                                 Text="7"
                                 PreviewTextInput="NumberValidationTextBox"/>
                    </DockPanel>
                </StackPanel>
            </GroupBox>

            <!-- Дополнительные функции -->
            <GroupBox Header="Дополнительные функции" Padding="15">
                <StackPanel>
                    <CheckBox x:Name="chkTips" 
                              Content="Включить подсказки при запуске" 
                              IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="chkSound" 
                              Content="Включить звуковые уведомления" 
                              IsChecked="False" Margin="0,0,0,8"/>
                    <CheckBox x:Name="chkHotkeys" 
                              Content="Включить горячие клавиши" 
                              IsChecked="True"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Width="130" Height="38" 
                    Style="{StaticResource RtlPrimaryButton}" 
                    Click="BtnSave_Click" Margin="0,0,10,0"/>
            <Button Content="Отмена" Width="110" Height="38" 
                    Background="#6C757D" Foreground="White" 
                    BorderThickness="0" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>