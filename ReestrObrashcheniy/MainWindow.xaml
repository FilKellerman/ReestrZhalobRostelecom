<Window x:Class="ReestrObrashcheniy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Реестр жалоб и обращений — Ростелеком"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Фирменные цвета Ростелекома -->
        <SolidColorBrush x:Key="RostelecomBlue" Color="#0055A5"/>
        <SolidColorBrush x:Key="RostelecomBlueHover" Color="#0066C2"/>
        <SolidColorBrush x:Key="RostelecomOrange" Color="#FF6600"/>
        <SolidColorBrush x:Key="GrayDark" Color="#333333"/>
        <SolidColorBrush x:Key="GrayLight" Color="#D0D7E0"/>
        <SolidColorBrush x:Key="LightGray" Color="#F5F7FA"/>

        <!-- Стиль TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource GrayDark}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource RostelecomBlue}"
                                BorderThickness="0,0,0,7">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource RostelecomBlue}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0,0,0,4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource RostelecomBlueHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль заголовков DataGrid -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource RostelecomBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Стиль кнопок -->
        <Style x:Key="RtlButton" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="{StaticResource RostelecomOrange}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF8533"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E65C00"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль поля поиска -->
        <Style x:Key="RtlSearchTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource GrayLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource RostelecomBlue}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Заголовок приложения -->
        <Border Background="{StaticResource RostelecomBlue}" Height="60" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <TextBlock Text="Реестр жалоб и обращений"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="txtПриветствие"
                           Foreground="White"
                           FontSize="16"
                           Margin="40,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Кнопка выхода -->
        <Button Content="Выход"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,12,20,0"
                Width="100"
                Style="{StaticResource RtlButton}"
                Background="#FF6600"
                Click="BtnExit_Click"/>

        <!-- Основной TabControl -->
        <TabControl Margin="0,60,0,0" Background="Transparent">
            <!-- Вкладка Обращения -->
            <TabItem x:Name="tabОбращения" Header="Обращения">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Поиск -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Поиск по описанию / клиенту / статусу:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="14"/>
                        <TextBox x:Name="txtПоискОбращение"
                                 Width="350"
                                 Style="{StaticResource RtlSearchTextBox}"
                                 TextChanged="TxtПоискОбращение_TextChanged"/>
                    </StackPanel>

                    <!-- Таблица -->
                    <DataGrid x:Name="dgОбращения" Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#E8F0FE"
                              RowBackground="White"
                              Margin="0,0,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding Клиент_ФИО}" Width="200"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Описание}" Width="*"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding ДатаПоступления, StringFormat=dd.MM.yyyy}" Width="100"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="120"/>
                            <DataGridTextColumn Header="Сотрудник" Binding="{Binding Сотрудник_ФИО}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Добавить" Style="{StaticResource RtlButton}" Click="BtnAddОбращение_Click"/>
                        <Button Content="Редактировать" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnEditОбращение_Click"/>
                        <Button Content="Удалить" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnDeleteОбращение_Click"/>
                        <Button x:Name="BtnChangeStatus" Content="Изменить статус" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnChangeStatus_Click"/>
                        <Button x:Name="BtnAddОтвет" Content="Добавить ответ" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnAddОтвет_Click"/>
                        <Button Content="Экспорт в CSV" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnExportCSVWithSaveDialog_Click"/>
                        <Button Content="Подсказка" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnПодсказка_Click"/>
                        <Button Content="Поиск" Style="{StaticResource RtlButton}" Width="100" Margin="10,0,0,0" Click="BtnПоиск_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка Клиенты -->
            <TabItem x:Name="tabКлиенты" Header="Клиенты">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Поиск по ФИО:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                        <TextBox x:Name="txtПоискКлиент" Width="300" Style="{StaticResource RtlSearchTextBox}" TextChanged="TxtПоискКлиент_TextChanged"/>
                    </StackPanel>

                    <DataGrid x:Name="dgКлиенты" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              AlternatingRowBackground="#E8F0FE" RowBackground="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding ФИО}" Width="*"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Адрес}" Width="300"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Телефон}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,15,0,0">
                        <Button Content="Добавить" Style="{StaticResource RtlButton}" Click="BtnAddКлиент_Click"/>
                        <Button Content="Редактировать" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnEditКлиент_Click"/>
                        <Button Content="Удалить" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnDeleteКлиент_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка Сотрудники -->
            <TabItem x:Name="tabСотрудники" Header="Сотрудники">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Поиск по ФИО:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                        <TextBox x:Name="txtПоискСотрудник" Width="300" Style="{StaticResource RtlSearchTextBox}" TextChanged="TxtПоискСотрудник_TextChanged"/>
                    </StackPanel>

                    <DataGrid x:Name="dgСотрудники" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              AlternatingRowBackground="#E8F0FE" RowBackground="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding ФИО}" Width="*"/>
                            <DataGridTextColumn Header="Должность" Binding="{Binding Должность}" Width="200"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="250"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Телефон}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,15,0,0">
                        <Button Content="Добавить" Style="{StaticResource RtlButton}" Click="BtnAddСотрудник_Click"/>
                        <Button Content="Редактировать" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnEditСотрудник_Click"/>
                        <Button Content="Удалить" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnDeleteСотрудник_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка Ответы -->
            <TabItem x:Name="tabОтветы" Header="Ответы">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Поиск по тексту / сотруднику:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                        <TextBox x:Name="txtПоискОтвет" Width="350" Style="{StaticResource RtlSearchTextBox}" TextChanged="TxtПоискОтвет_TextChanged"/>
                    </StackPanel>

                    <DataGrid x:Name="dgОтветы" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              AlternatingRowBackground="#E8F0FE" RowBackground="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                            <DataGridTextColumn Header="Обращение ID" Binding="{Binding Обращение_ID}" Width="80"/>
                            <DataGridTextColumn Header="Сотрудник" Binding="{Binding Сотрудник_ФИО}" Width="200"/>
                            <DataGridTextColumn Header="Текст" Binding="{Binding Текст}" Width="*"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding ДатаОтвета, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                            <DataGridCheckBoxColumn Header="Внутренний" Binding="{Binding ЭтоВнутренний}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,15,0,0">
                        <Button Content="Добавить" Style="{StaticResource RtlButton}" Click="BtnAddОтвет_Click"/>
                        <Button Content="Редактировать" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnEditОтвет_Click"/>
                        <Button Content="Удалить" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnDeleteОтвет_Click"/>
                        <Button Content="Уведомление оператору" Style="{StaticResource RtlButton}" Margin="10,0,0,0" Click="BtnУведомлениеОператору_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>