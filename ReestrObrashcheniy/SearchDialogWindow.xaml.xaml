<Window x:Class="ReestrObrashcheniy.SearchDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поиск обращений" 
        Height="360" Width="520"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Фирменные цвета Ростелекома (как в главном окне) -->
        <SolidColorBrush x:Key="RostelecomBlue" Color="#0055A5"/>
        <SolidColorBrush x:Key="RostelecomBlueHover" Color="#0066C2"/>
        <SolidColorBrush x:Key="RostelecomGray" Color="#6C757D"/>
        <SolidColorBrush x:Key="GrayDark" Color="#333333"/>
        <SolidColorBrush x:Key="GrayLight" Color="#D0D7E0"/>

        <!-- Стиль TextBox (как в главном окне) -->
        <Style x:Key="RtlTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource GrayLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource RostelecomBlue}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль ComboBox (как в главном окне) -->
        <Style x:Key="RtlComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource GrayLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource RostelecomBlue}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль кнопки (как в главном окне) -->
        <Style x:Key="RtlButton" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Основная кнопка "Найти" -->
        <Style x:Key="RtlPrimaryButton" BasedOn="{StaticResource RtlButton}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource RostelecomBlue}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RostelecomBlueHover}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004488"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Вторичная кнопка "Отмена" -->
        <Style x:Key="RtlSecondaryButton" BasedOn="{StaticResource RtlButton}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource RostelecomGray}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5A6268"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль TextBlock -->
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource GrayDark}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Заголовок в фирменном стиле -->
        <Border Background="{StaticResource RostelecomBlue}" Height="50" VerticalAlignment="Top">
            <TextBlock Text="Поиск обращений"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Основное содержимое -->
        <Grid Margin="20,60,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Описание содержит:"/>
            <TextBox x:Name="txtОписание" Grid.Row="1" Style="{StaticResource RtlTextBox}" />

            <TextBlock Grid.Row="2" Text="ФИО клиента содержит:"/>
            <TextBox x:Name="txtФИОКлиента" Grid.Row="3" Style="{StaticResource RtlTextBox}" />

            <TextBlock Grid.Row="4" Text="Статус:"/>
            <ComboBox x:Name="cmbСтатус" Grid.Row="5" Style="{StaticResource RtlComboBox}" SelectedIndex="0">
                <ComboBoxItem Content="Все"/>
                <ComboBoxItem Content="Новая"/>
                <ComboBoxItem Content="В обработке"/>
                <ComboBoxItem Content="На уточнении"/>
                <ComboBoxItem Content="Закрыта"/>
                <ComboBoxItem Content="Отклонена"/>
            </ComboBox>

            <!-- Кнопки -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Отмена" Style="{StaticResource RtlSecondaryButton}" Click="BtnCancel_Click"/>
                <Button Content="Найти" Style="{StaticResource RtlPrimaryButton}" Margin="15,0,0,0" Click="BtnSearch_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>